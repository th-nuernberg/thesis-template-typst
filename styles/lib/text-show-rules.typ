#show regex("u\.\s?a\."):       [u.\u{202F}a.]
#show regex("d\.\s?h\."):       [d.\u{202F}h.]
#show regex("e\.\s?g\."):       [e.\u{FEFF}g.]
#show regex("i\.\s?e\."):       [i.\u{FEFF}e.]
#show regex("w\.\s?r\.\s?t\."): [w.\u{FEFF}r.\u{FEFF}t.]
